{
  "manifest_version": 3,
  "name": "MakerLab Config Saver",
  "version": "1.3.0",
  "description": "Save and restore MakerLab customisation options on MakerWorld",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://makerworld.com/*",
    "https://www.makerworld.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://makerworld.com/*",
        "https://www.makerworld.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://makerworld.com/*",
        "https://www.makerworld.com/*"
      ],
      "js": ["inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
